<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.toyotec_jp.uslim.sita.dao.SitaMapper">

	<!--下取予定車両仕分け条件-->
	<sql id="sitaCond">
		<!--車両仕分け条件(年式)-->
		<if test="sitaCondSyodo != null">
			AND T1.SU_SYODOTOR <![CDATA[ >= ]]> #{sitaCondSyodo}
		</if>
		<!--車両仕分け条件(走行距離)-->
		<if test="sitaCondSoukou != null">
			AND T1.NU_SOUKOUKM <![CDATA[ <= ]]> #{sitaCondSoukou}
		</if>
		<!--車両仕分け条件(メーカー)-->
		<if test="sitaCondMaker != null and sitaCondMaker.size() > 0">
			AND T6.CD_MAKER NOT IN 
			<foreach item="item" collection="sitaCondMaker" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(車名)-->
		<if test="sitaCondSyamei != null and sitaCondSyamei.size() > 0">
			AND T6.CD_SYAMEI NOT IN 
			<foreach item="item" collection="sitaCondSyamei" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(修復歴)-->
		<if test="sitaCondSyufuku != null and sitaCondSyufuku.size() > 0">
			AND T1.CD_SYUFUKRE IN 
			<foreach item="item" collection="sitaCondSyufuku" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(仕分け区分)-->
		<if test="sitaCondShiwake != null and sitaCondShiwake.size() > 0">
			AND T1.KB_URIAGYOT IN 
			<foreach item="item" collection="sitaCondShiwake" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(評価点)-->
		<if test="sitaCondHyoka != null and sitaCondHyoka.size() > 0">
			AND NVL(RTRIM(T14.NU_SUHKT), '') IN 
			<foreach item="item" collection="sitaCondHyoka" open="(" separator="," close=")">#{item}</foreach>
		</if>
	</sql>

	<!--在庫車両仕分け条件-->
	<sql id="zaikoCond">
		<!--車両仕分け条件(年式)-->
		<if test="zaikoCondSyodo != null">
			AND T1.SU_SYODOTOR <![CDATA[ >= ]]> #{zaikoCondSyodo}
		</if>
		<!--車両仕分け条件(走行距離)-->
		<if test="zaikoCondSoukou != null">
			AND T1.NU_SOUKOUKM <![CDATA[ <= ]]> #{zaikoCondSoukou}
		</if>
		<!--車両仕分け条件(メーカー)-->
		<if test="zaikoCondMaker != null and zaikoCondMaker.size() > 0">
			AND T6.CD_MAKER NOT IN  
			<foreach item="item" collection="zaikoCondMaker" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(車名)-->
		<if test="zaikoCondSyamei != null and zaikoCondSyamei.size() > 0">
			AND T6.CD_SYAMEI NOT IN  
			<foreach item="item" collection="zaikoCondSyamei" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(修復歴)-->
		<if test="zaikoCondSyufuku != null and zaikoCondSyufuku.size() > 0">
			AND T1.CD_SYUFUKRE IN  
			<foreach item="item" collection="zaikoCondSyufuku" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(仕分け区分)-->
		<if test="zaikoCondShiwake != null and zaikoCondShiwake.size() > 0">
			AND T1.KB_URIAGYOT IN  
			<foreach item="item" collection="zaikoCondShiwake" open="(" separator="," close=")">#{item}</foreach>
		</if>
		<!--車両仕分け条件(評価点)-->
		<if test="zaikoCondHyoka != null and zaikoCondHyoka.size() > 0">
			AND NVL(RTRIM(T14.NU_SUHKT), '') IN  
			<foreach item="item" collection="zaikoCondHyoka" open="(" separator="," close=")">#{item}</foreach>
		</if>
	</sql>

	<!--下取・在庫情報取得条件-->
	<sql id="sitaZaikoWhereClause">
		WHERE 
			T1.RN = 1
			<!--本部店舗区分-->
			<if test="kbHonTen == '2'.toString()">
				<choose>
				<when test="showSitaCond and showZaikoCond">
					AND (
						T1.CD_WEB = '1' 
						OR (T1.CD_WEB = '' 
							<include refid="sitaCond"/>)
						OR (T1.CD_WEB = '0' 
							<include refid="zaikoCond"/>)
					)
				</when>
				<when test="showSitaCond">
					AND (
						T1.CD_WEB IN ('0', '1') 
						OR (T1.CD_WEB = '' 
							<include refid="sitaCond"/>)
					)
				</when>
				<when test="showZaikoCond">
					AND (
						T1.CD_WEB IN ('', '1') 
						OR (T1.CD_WEB = '0' 
							<include refid="zaikoCond"/>)
					)
				</when>
				</choose>
			</if>
			<!--車台番号-->
			<if test="syadaiba != null and syadaiba != ''">
				AND T1.NO_SYADAIBA LIKE CONCAT('%', #{syadaiba}, '%')
			</if>
			<!--車両NO-->
			<if test="noSyaryou != null and noSyaryou != ''">
				AND LEFT(REPLACE(T1.NO_SYARYOU,' ',''),LENGTH(#{noSyaryou})) = #{noSyaryou}
			</if>
			<!--カテゴリーコード-->
			<if test="kategori != null and kategori.size() > 0">
				AND T23.CD_TNJCATE IN 
				<foreach item="item" collection="kategori" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--型式-->
			<if test="katasiki != null and katasiki.size() > 0">
				AND
				<foreach item="item" collection="katasiki" open="(" separator=" or " close=")">
				LEFT(REGEXP_REPLACE(T1.MJ_KATASIKI, '[　 ]+$', '') ,LENGTH(#{item})) = #{item}
				</foreach>
			</if>
			<!--年式最小値 年式最大値-->
			<choose>
			<when test="syodotorMin != null and syodotorMin > 0 and syodotorMax != null and syodotorMax > 0">
				AND T1.SU_SYODOTOR BETWEEN #{syodotorMin} AND #{syodotorMax}
			</when>
			<when test="syodotorMin != null and syodotorMin > 0">
				AND T1.SU_SYODOTOR <![CDATA[ >= ]]> #{syodotorMin}
			</when>
			<when test="syodotorMax != null and syodotorMax > 0">
				AND T1.SU_SYODOTOR != 0
				AND T1.SU_SYODOTOR <![CDATA[ <= ]]> #{syodotorMax}
			</when>
			</choose>
			<!--走行距離最小値 走行距離最大値-->
			<choose>
			<when test="soukoukiroMin != null and soukoukiroMin > 0 and soukoukiroMax != null and soukoukiroMax > 0">
				AND T1.NU_SOUKOUKM BETWEEN #{soukoukiroMin} AND #{soukoukiroMax}
			</when>
			<when test="soukoukiroMin != null and soukoukiroMin > 0">
				AND T1.NU_SOUKOUKM <![CDATA[ >= ]]> #{soukoukiroMin}
			</when>
			<when test="soukoukiroMax != null and soukoukiroMax > 0">
				AND T1.NU_SOUKOUKM <![CDATA[ <= ]]> #{soukoukiroMax}
			</when>
			</choose>
			<!--エンジン-->
			<if test="unito != null and unito.size() > 0">
				AND T1.KB_ENGINE IN 
				<foreach item="item" collection="unito" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--車名コード-->
			<if test="syamei != null and syamei.size() > 0">
				AND T1.CD_SYAMEI IN 
				<foreach item="item" collection="syamei" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--ウェルキャブ-->
			<if test="welcab != null and welcab != ''">
				AND T1.MJ_21SYANIN = #{welcab}
			</if>
			<!--バントラ区分 バン&トラ-->
			<if test="banTora != null and banTora.size() > 0">
				AND T6.KB_BANTORA IN 
				<foreach item="item" collection="banTora" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--メーカーコード-->
			<if test="maker != null and maker.size() > 0">
				AND RTRIM(T6.CD_MAKER) IN 
				<foreach item="item" collection="maker" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--在庫照会用色コード-->
			<if test="tosikime != null and tosikime.size() > 0">
				<choose>
				<when test="tosikime.contains('16')">
					AND (
						T27.UCAR_BODY_COLOR_CD IS NULL
						OR T27.SEARCH_COLOR_CD IN
						<foreach item="item" collection="tosikime" open="(" separator="," close=")">#{item}</foreach>
					)
				</when>
				<otherwise>
					AND T27.SEARCH_COLOR_CD IN
					<foreach item="item" collection="tosikime" open="(" separator="," close=")">#{item}</foreach>
				</otherwise>
				</choose>
			</if>
			<!--内装色コード-->
			<if test="naisou != null and naisou.size() > 0">
				AND T10.CD_NISCLR IN 
				<foreach item="item" collection="naisou" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--グレード-->
			<if test="guredo != null and guredo.size() > 0">
				<!--指定類別有無-->
				<choose>
				<when test="kbSiteruib">
					AND NVL(NULLIF(RTRIM(T26.MJ_GUREDO), ''), 'その他') IN 
				</when>
				<otherwise>
					AND NVL(NULLIF(RTRIM(T10.MJ_GUREDO), ''), 'その他') IN 
				</otherwise>
				</choose>
				<foreach item="item" collection="guredo" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--駆動方式-->
			<if test="kudohoho != null and kudohoho.size() > 0">
				AND T1.KB_KUDOHOHO IN 
				<foreach item="item" collection="kudohoho" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--下取予定日最小値 下取予定日最大値-->
			<choose>
			<when test="ddSitayoteMin != null and ddSitayoteMax != null ">
				AND T1.DD_SITAYOTE BETWEEN #{ddSitayoteMin} AND #{ddSitayoteMax}
			</when>
			<when test="ddSitayoteMin != null ">
				AND T1.DD_SITAYOTE <![CDATA[ >= ]]> #{ddSitayoteMin}
			</when>
			<when test="ddSitayoteMax != null">
				AND T1.DD_SITAYOTE <![CDATA[ <= ]]> #{ddSitayoteMax}
			</when>
			</choose>
			<!--販売価格最小値 販売価格最大値-->
			<choose>
			<when test="hanbaikkMin != null and hanbaikkMin > 0 and hanbaikkMax != null and hanbaikkMax > 0">
				AND T1.KI_HNBSIJIK BETWEEN #{hanbaikkMin} AND #{hanbaikkMax}
			</when>
			<when test="hanbaikkMin != null and hanbaikkMin > 0">
				AND T1.KI_HNBSIJIK <![CDATA[ >= ]]> #{hanbaikkMin}
			</when>
			<when test="hanbaikkMax != null and hanbaikkMax > 0">
				AND T1.KI_HNBSIJIK <![CDATA[ <= ]]> #{hanbaikkMax}
			</when>
			</choose>
	</sql>

	<!--共有在庫情報取得条件-->
	<sql id="kyoyuWhereClause">
		WHERE 
			T1.CD_TMCHANCD != #{cdHanbaitn}
			<!--車名コード-->
			<if test="syamei != null and syamei.size() > 0">
				AND T1.CD_SYAMEIAI IN 
				<foreach item="item" collection="syamei" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--車台番号-->
			<if test="syadaiba != null and syadaiba != ''">
				AND T1.NO_SYADAIBA LIKE CONCAT('%', #{syadaiba}, '%')
			</if>
			<!--車両NO-->
			<if test="noSyaryou != null and noSyaryou != ''">
				AND LEFT(REPLACE(T1.NO_SYARYOU,' ',''),LENGTH(#{noSyaryou})) = #{noSyaryou}
			</if>
			<!--型式-->
			<if test="katasiki != null and katasiki.size() > 0">
				AND 
				<foreach item="item" collection="katasiki" open="(" separator=" or " close=")">
				LEFT(REGEXP_REPLACE(T1.MJ_KATASIKI, '[　 ]+$', '') ,LENGTH(#{item})) = #{item}
				</foreach>
			</if>
			<!--年式最小値 年式最大値-->
			<choose>
			<when test="syodotorMin != null and syodotorMin >0 and syodotorMax != null and syodotorMax > 0">
				AND NVL(CAST(T1.SU_SYODOTOR AS INT), 0) BETWEEN #{syodotorMin} AND #{syodotorMax}
			</when>
			<when test="syodotorMin != null and syodotorMin != ''">
				AND NVL(CAST(T1.SU_SYODOTOR AS INT), 0) <![CDATA[ >= ]]> #{syodotorMin}
			</when>
			<when test="syodotorMax != null and syodotorMax != ''">
				AND NVL(CAST(T1.SU_SYODOTOR AS INT), 0) != 0
				AND NVL(CAST(T1.SU_SYODOTOR AS INT), 0) <![CDATA[ <= ]]> #{syodotorMax}
			</when>
			</choose>
			<!--走行距離最小値 走行距離最大値-->
			<choose>
			<when test="soukoukiroMin != null and soukoukiroMin > 0 and soukoukiroMax != null and soukoukiroMax > 0">
				AND (CASE WHEN T1.KB_METTKRK IS NULL OR RTRIM(T1.KB_METTKRK) = '' THEN CAST(T1.NU_SOUKOUKM AS INT)
						WHEN T1.KB_METTKRK = '3' THEN CAST(T1.NU_SOUKOKM2 AS INT) + CAST(T1.NU_SOUKOKMSAN AS INT)
						WHEN T1.KB_METTKRK IN ('1', '2', '4') THEN NULL
						ELSE 0 END) BETWEEN #{soukoukiroMin} AND #{soukoukiroMax}
			</when>
			<when test="soukoukiroMin != null and soukoukiroMin > 0">
				AND (CASE WHEN T1.KB_METTKRK IS NULL OR RTRIM(T1.KB_METTKRK) ='' THEN CAST(T1.NU_SOUKOUKM AS INT)
						WHEN T1.KB_METTKRK = '3' THEN CAST(T1.NU_SOUKOKM2 AS INT) + CAST(T1.NU_SOUKOKMSAN AS INT)
						WHEN T1.KB_METTKRK IN ('1', '2', '4') THEN NULL
						ELSE 0 END) <![CDATA[ >= ]]> #{soukoukiroMin}
			</when>
			<when test="soukoukiroMax != null and soukoukiroMax > 0">
				AND (CASE WHEN T1.KB_METTKRK IS NULL OR RTRIM(T1.KB_METTKRK) ='' THEN CAST(T1.NU_SOUKOUKM AS INT)
						WHEN T1.KB_METTKRK = '3' THEN CAST(T1.NU_SOUKOKM2 AS INT) + CAST(T1.NU_SOUKOKMSAN AS INT)
						WHEN T1.KB_METTKRK IN ('1', '2', '4') THEN NULL
						ELSE 0 END) <![CDATA[ <= ]]> #{soukoukiroMax}
			</when>
			</choose>
			<!--中古車塗色コード-->
			<if test="tosikime != null and tosikime.size() > 0">
				<choose>
				<when test="tosikime.contains('16')">
					AND (
						T1.CD_HYOJICOL = '0'
						OR T1.CD_HYOJICOL IN 
						<foreach item="item" collection="tosikime" open="(" separator="," close=")">#{item}</foreach>
					)
				</when>
				<otherwise>
					AND T1.CD_HYOJICOL IN 
					<foreach item="item" collection="tosikime" open="(" separator="," close=")">#{item}</foreach>
				</otherwise>
				</choose>
			</if>
			<!--メーカーコード-->
			<if test="maker != null and maker.size() > 0">
				AND CASE WHEN RTRIM(T1.CD_MAKER) <![CDATA[ <> ]]> '12' THEN RTRIM(T1.CD_MAKER)
					     WHEN TBV0205M.CD_MAKER IS NOT NULL THEN TBV0205M.CD_MAKER
					     ELSE '01'
					END IN 
				<foreach item="item" collection="maker" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--内装色コード-->
			<if test="naisou != null and naisou.size() > 0">
				AND T1.CD_NAISO IN 
				<foreach item="item" collection="naisou" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--カテゴリーコード-->
			<if test="kategori != null and kategori.size() > 0">
				AND T1.CD_TNJCATE IN 
				<foreach item="item" collection="kategori" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--グレード-->
			<if test="guredo != null and guredo.size() > 0">
				AND NVL(NULLIF(RTRIM(T1.MJ_GUREDO), ''), 'その他') IN 
				<foreach item="item" collection="guredo" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--駆動方式-->
			<if test="kudohoho != null and kudohoho.size() > 0">
				AND T1.KB_KUDOHOHO IN 
				<foreach item="item" collection="kudohoho" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--エンジン-->
			<if test="unito != null and unito.size() > 0">
				AND RTRIM(T1.KB_ENGINE) IN 
				<foreach item="item" collection="unito" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--ウェルキャブ-->
			<if test="welcab != null and welcab != ''">
				AND RIGHT(T1.CD_SYAMEIAI, 2) = #{welcab}
			</if>
			<!--販売価格最小値 販売価格最大値-->
			<choose>
			<when test="hanbaikkMin != null and hanbaikkMin > 0 and hanbaikkMax != null and hanbaikkMax > 0">
				AND ROUND(T1.KI_SYRYOHON / 1000) BETWEEN #{hanbaikkMin} AND #{hanbaikkMax}
			</when>
			<when test="hanbaikkMin != null and hanbaikkMin > 0">
				AND ROUND(T1.KI_SYRYOHON / 1000) <![CDATA[ >= ]]> #{hanbaikkMin}
			</when>
			<when test="hanbaikkMax != null and hanbaikkMax > 0">
				AND ROUND(T1.KI_SYRYOHON / 1000) <![CDATA[ <= ]]> #{hanbaikkMax}
			</when>
			</choose>
			<!--Gazoo販売店コード-->
			<if test="gazooCdHansya != null and gazooCdHansya.size() > 0">
				AND T1.CD_TMCHANCD IN 
				<foreach item="item" collection="gazooCdHansya" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
			<!--Gazoo販社都道府県コード-->
			<if test="gazooCdTodofken != null and gazooCdTodofken.size() > 0">
				AND T1.CD_TODOFKEN IN 
				<foreach item="item" collection="gazooCdTodofken" open="(" separator="," close=")">
				#{item}
				</foreach>
			</if>
	</sql>

	<!--車両台数情報を取得する-->
	<resultMap id="syaryouDaisuResultMap" type="com.toyotec_jp.uslim.sita.model.SyaryouDaisuMap">
		<id property="category" column="CATEGORY"/>
		<collection property="syaryouDaisuList" ofType="com.toyotec_jp.uslim.sita.model.SyaryouDaisuItem">
			<result property="sitaMonthWeek" column="SITA_MONTH_WEEK"/>
			<result property="status" column="STATUS"/>
			<result property="kbUriagyot" column="KB_URIAGYOT"/>
			<result property="syamei" column="SYAMEI"/>
			<result property="daisu" column="DAISU"/>
		</collection>
	</resultMap>
    <select id="getSyaryouDaisu" parameterType="map" resultMap="syaryouDaisuResultMap">
	    SELECT
    	    category AS CATEGORY,
	        sita_month_week AS SITA_MONTH_WEEK,
    	    status AS STATUS,
        	kb_uriagyot AS KB_URIAGYOT,
	        syamei AS SYAMEI,
    	    daisu AS DAISU
	    FROM ${uslimDb}.DM_SITA_VEHICLE_DAISU
    	WHERE cd_hansya = #{cdHansya}
    		AND cd_kaisya = #{cdKaisya}
    		AND cd_hanbaitn = #{cdHanbaitn}
    		AND kb_honten = #{kbHonTen}
    	ORDER BY category, sita_month_week, daisu_rank
	</select>

	<!--車両明細情報を取得する-->
	<select id="getSyaryouMeisai" parameterType="map" resultType="com.toyotec_jp.uslim.sita.model.SyaryouMeisai">
	    SELECT
	        cd_teanyote AS CD_TEANYOTE,
	        no_syadaiba AS NO_SYADAIBA,
    	    no_syaryou AS NO_SYARYOU,
        	no_siretyum AS NO_SIRETYUM,
	        '' AS MJ_SIRENORI,
    	    '' AS KB_SIRETOSY,
        	'' AS CD_SIRETOGY,
	        '' AS NO_SIRETOSE,
    	    '' AS NO_LEASE,
        	'' AS NO_KOTESISN,
	        status AS STATUS,
    	    mj_ncfr AS MJ_NCFR,
        	dd_syodotor AS DD_SYODOTOR,
	        dd_syknmanr AS DD_SYKNMANR,
    	    mj_katasiki AS MJ_KATASIKI,
        	ki_hnbsijik AS KI_HNBSIJIK,
	        nu_soukoukm AS NU_SOUKOUKM,
    	    mj_syamei AS MJ_SYAMEI,
        	kb_uriagyot AS KB_URIAGYOT,
	        dd_sitayote AS DD_SITAYOTE,
    	    dd_kibonoki AS DD_KIBONOKI,
        	cd_syufukre AS CD_SYUFUKRE,
	        cd_web AS CD_WEB,
    	    kj_syainmei AS KJ_SYAINMEI,
        	kj_tentanms AS KJ_TENTANMS,
	        mj_todofkenfl AS MJ_TODOFKENFL,
    	    kj_zaikoten AS KJ_ZAIKOTEN,
        	ki_sitadkak AS KI_SITADKAK,
	        nu_suhkt AS NU_SUHKT,
    	    ki_nesita AS KI_NESITA,
        	kj_tosikime AS KJ_TOSIKIME,
	        mj_nisclr AS MJ_NISCLR,
