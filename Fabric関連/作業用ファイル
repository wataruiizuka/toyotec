SELECT
  COUNT(*) AS total_count,

  COUNT(cd_hansya) AS cd_hansya_count,
  COUNT(cd_kaisya) AS cd_kaisya_count,
  COUNT(cd_tenpo) AS cd_tenpo_count,

  COUNT(dd_jucyu) AS dd_jucyu_count,
  MIN(dd_jucyu) AS min_dd_jucyu,
  MAX(dd_jucyu) AS max_dd_jucyu,

  COUNT(DISTINCT cd_hansya) AS distinct_cd_hansya,
  COUNT(DISTINCT cd_kaisya) AS distinct_cd_kaisya,
  COUNT(DISTINCT cd_tenpo) AS distinct_cd_tenpo,

  COUNT(DISTINCT CONCAT(
    cd_hansya,
    '|',
    cd_kaisya,
    '|',
    no_cyumon,
    '|',
    no_cyumoned
  )) AS distinct_order_detail_count
FROM bronze.tbba001g;
