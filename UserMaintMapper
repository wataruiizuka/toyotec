-- DM_USERMAINT_USER_GET
TRUNCATE TABLE gold.DM_USERMAINT_USER_GET;

INSERT INTO gold.DM_USERMAINT_USER_GET (
    cd_hansya,
    cd_kaisya,
    cd_user,
    cd_syain,
    mj_name,
    cd_tenpo,
    kj_tenpomei,
    kb_lexusten,
    mart_created_at
)
SELECT
    tbv0014m.cd_hansya,
    tbv0014m.cd_kaisya,
    NULL AS cd_user,
    tbv0014m.cd_syain,
    tbv0014m.kj_syainmei AS mj_name,
    tbv0201m.cd_tenpo,
    REGEXP_REPLACE(tbv0201m.kj_tentanms, '[　 ]+$', '') AS kj_tenpomei,
    CASE tbv0201m.kb_duotenpo WHEN '6' THEN '1' ELSE '0' END AS kb_lexusten,
    NOW()
FROM ai21rep_ve.TBV0014M tbv0014m
LEFT JOIN ai21rep_ve.TBV0201M tbv0201m
  ON tbv0014m.cd_hansya = tbv0201m.cd_hansya
 AND tbv0014m.cd_kaisya = tbv0201m.cd_kaisya
 AND tbv0014m.cd_syozoten = tbv0201m.cd_tenpo
WHERE tbv0014m.dd_taisyoku IS NULL;
