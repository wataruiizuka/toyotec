    nu_zaikonis,
    kb_tstihsk,
    dd_tstisgjs,
    dd_stisgjs,
    kb_sintyaku,
    mart_created_at
)
SELECT
    #{cdHansya},
    #{cdKaisya},
    #{cdHanbaitn},
    no_syadaiba,
    no_syaryou,
    no_siretyum,
    cd_teanyote,
    status,
    mj_ncfr,
    CASE WHEN su_syodotor IS NULL OR su_syodotor = 0 THEN '' ELSE FROM_UNIXTIME(UNIX_TIMESTAMP(CAST(su_syodotor * 100 + 1 AS STRING), 'yyyyMMdd'), 'yyyy/MM/dd') END,
    CASE WHEN dd_syknmanr <= CAST(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST') AS DATE) THEN '' ELSE FROM_TIMESTAMP(dd_syknmanr, 'yyyy/MM/dd') END,
    mj_katasiki,
    ki_hnbsijik,
    nu_soukoukm,
