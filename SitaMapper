-- DM_SITA_VEHICLE_DAISU
TRUNCATE TABLE ${uslimDb}.DM_SITA_VEHICLE_DAISU;

INSERT INTO ${uslimDb}.DM_SITA_VEHICLE_DAISU (
    cd_hansya,
    cd_kaisya,
    cd_hanbaitn,
    kb_honten,
    category,
    sita_month_week,
    status,
    kb_uriagyot,
    syamei,
    daisu,
    daisu_rank,
    mart_created_at
)
SELECT
    #{cdHansya},
    #{cdKaisya},
    #{cdHanbaitn},
    #{kbHonTen},
    category,
    sita_month_week,
    status,
    kb_uriagyot,
    syamei,
    daisu,
    daisu_rank,
    CURRENT_TIMESTAMP
FROM (
    SELECT
        CASE
            WHEN GROUPING(sita_month_week) = 0 THEN 1
            WHEN GROUPING(status) = 0 THEN 2
            WHEN GROUPING(mj_syamei) = 0 THEN 3
            ELSE NULL
        END AS category,
        sita_month_week,
        status,
        kb_uriagyot,
        mj_syamei AS syamei,
        COUNT(1) AS daisu,
        DENSE_RANK() OVER (PARTITION BY GROUPING(mj_syamei) ORDER BY COUNT(1) DESC) AS daisu_rank
    FROM (
        SELECT
            CASE
                WHEN status = '2' THEN NULL
                WHEN dd_sitayote IS NULL THEN NULL
                WHEN #{kbHonTen} = '1' AND dd_sitayote < CAST(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST') AS DATE)
                    THEN FROM_TIMESTAMP(DAYS_SUB(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST'), 1), ' ~yyyy/MM/dd')
                WHEN #{kbHonTen} = '1'
                    THEN FROM_TIMESTAMP(dd_sitayote, 'yyyy/MM')
                WHEN #{kbHonTen} = '2' AND dd_sitayote < CAST(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST') AS DATE)
                    THEN FROM_TIMESTAMP(DAYS_SUB(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST'), 1), ' ~yyyy/MM/dd')
                WHEN #{kbHonTen} = '2' AND DAYS_SUB(dd_sitayote, (5 + DAYOFWEEK(dd_sitayote)) % 7) < CAST(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST') AS DATE)
                    THEN FROM_TIMESTAMP(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST'), 'yyyy/MM/dd~')
                WHEN #{kbHonTen} = '2'
                    THEN FROM_TIMESTAMP(DAYS_SUB(dd_sitayote, (5 + DAYOFWEEK(dd_sitayote)) % 7), 'yyyy/MM/dd~')
                ELSE NULL
            END AS sita_month_week,
            status,
            CASE
                WHEN status = '2' THEN ''
                WHEN kb_uriagyot = '1' THEN '小売'
                WHEN kb_uriagyot = '2' THEN '卸売'
                ELSE ''
            END AS kb_uriagyot,
            mj_syamei
        FROM ${uslimDb}.DM_SITA_VEHICLE_BASE
    ) T
    GROUP BY GROUPING SETS ((sita_month_week), (status, kb_uriagyot), (mj_syamei))
    HAVING (GROUPING(sita_month_week) = 0 AND sita_month_week IS NOT NULL)
        OR GROUPING(status) = 0
        OR (GROUPING(mj_syamei) = 0 AND mj_syamei IS NOT NULL)
) X
WHERE category IN (1, 2)
   OR (category = 3 AND daisu_rank <= 10);


