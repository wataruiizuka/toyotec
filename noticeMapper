-- DM_NOTICEINFO_ALL
TRUNCATE TABLE gold.DM_NOTICEINFO_ALL;

INSERT INTO gold.DM_NOTICEINFO_ALL (
    id_oshirase,
    cd_jyuyodo,
    dd_hashinbi,
    cd_categori,
    kj_naiyou,
    kb_taisyo,
    dd_to,
    sort_dd_hashinbi,
    sort_dt_saisinup,
    mart_created_at
)
SELECT
    id_oshirase,
    cd_jyuyodo,
    FROM_TIMESTAMP(dd_hashinbi, 'yyyy/MM/dd') AS dd_hashinbi,
    cd_categori,
    kj_naiyou,
    kb_taisyo,
    FROM_TIMESTAMP(dd_to, 'yyyy/MM/dd') AS dd_to,
    dd_hashinbi AS sort_dd_hashinbi,
    dt_saisinup AS sort_dt_saisinup,
    NOW()
FROM uslim_ve.NOTICEINFO;


-- DM_NOTICEINFO_PUBLISH

TRUNCATE TABLE gold.DM_NOTICEINFO_PUBLISH;

INSERT INTO gold.DM_NOTICEINFO_PUBLISH (
    id_oshirase,
    cd_jyuyodo,
    dd_hashinbi,
    cd_categori,
    kj_naiyou,
    kb_taisyo,
    dd_to,
    sort_dd_hashinbi,
    sort_dt_saisinup,
    mart_target_date,
    mart_created_at
)
SELECT
    id_oshirase,
    cd_jyuyodo,
    FROM_TIMESTAMP(dd_hashinbi, 'yyyy/MM/dd') AS dd_hashinbi,
    cd_categori,
    kj_naiyou,
    kb_taisyo,
    FROM_TIMESTAMP(dd_to, 'yyyy/MM/dd') AS dd_to,
    dd_hashinbi AS sort_dd_hashinbi,
    dt_saisinup AS sort_dt_saisinup,
    CAST(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST') AS DATE) AS mart_target_date,
    NOW()
FROM uslim_ve.NOTICEINFO
WHERE CAST(FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST') AS DATE)
      BETWEEN NVL(dd_hashinbi, DATE'1900-01-01')
          AND NVL(dd_to, DATE'9999-12-31');

