<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.toyotec_jp.uslim.common.dao.NoticeMapper">

    <!-- お知らせ情報取得SQL：DM参照版 -->
    <select id="getNoticeInfo" resultType="com.toyotec_jp.uslim.common.model.NoticeInfo">
        SELECT
            id_oshirase AS ID_OSHIRASE
            , cd_jyuyodo AS CD_JYUYODO
            , dd_hashinbi AS DD_HASHINBI
            , cd_categori AS CD_CATEGORI
            , kj_naiyou AS KJ_NAIYOU
            , kb_taisyo AS KB_TAISYO
            , dd_to AS DD_TO
        FROM ${uslimDb}.DM_NOTICEINFO_ALL
        ORDER BY
            sort_dd_hashinbi DESC
            , sort_dt_saisinup DESC
    </select>

    <!-- 掲載対象のお知らせ情報取得SQL：DM参照版 -->
    <select id="getPublishNoticeInfo" resultType="com.toyotec_jp.uslim.common.model.NoticeInfo">
        SELECT
            id_oshirase AS ID_OSHIRASE
            , cd_jyuyodo AS CD_JYUYODO
            , dd_hashinbi AS DD_HASHINBI
            , cd_categori AS CD_CATEGORI
            , kj_naiyou AS KJ_NAIYOU
            , kb_taisyo AS KB_TAISYO
            , dd_to AS DD_TO
        FROM ${uslimDb}.DM_NOTICEINFO_PUBLISH
        ORDER BY
            sort_dd_hashinbi DESC
            , sort_dt_saisinup DESC
    </select>

    <!-- お知らせ情報登録・更新SQL：元テーブル更新のまま -->
    <update id="updNoticeInfo" parameterType="com.toyotec_jp.uslim.common.model.NoticeInfo">
        UPSERT INTO ${uslimDb}.NOTICEINFO (
            ID_OSHIRASE
            ,CD_JYUYODO
            ,DD_HASHINBI
            ,CD_CATEGORI
            ,KJ_NAIYOU
            ,KB_TAISYO
            ,DD_TO
            ,MJ_SAKUSEISYA
            ,DT_SAKUSEI
            ,MJ_KOSINSYA
            ,DT_SAISINUP
        )
        SELECT 
            T_ID.ID_OSHIRASE
            ,#{cdJyuyodo}
            ,CAST(TO_TIMESTAMP(#{ddHashinbi, jdbcType=VARCHAR}, 'yyyy/MM/dd') AS DATE)
            ,#{cdCategori}
            ,#{kjNaiyou}
            ,#{kbTaisyo}
            ,CAST(TO_TIMESTAMP(#{ddTo, jdbcType=VARCHAR}, 'yyyy/MM/dd') AS DATE)
            ,NVL(T_NI.MJ_SAKUSEISYA, #{cdUser}) 
            ,NVL(T_NI.DT_SAKUSEI, FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST')) 
            ,#{cdUser}
            ,FROM_UTC_TIMESTAMP(UTC_TIMESTAMP(), 'JST')
        FROM 
            (VALUES(
            <choose>
            <when test="idOshirase != null and idOshirase != ''">
                #{idOshirase} AS ID_OSHIRASE
            </when>
            <otherwise>
                UUID() AS ID_OSHIRASE
            </otherwise>
            </choose>
            )) T_ID
            LEFT JOIN ${uslimDb}.NOTICEINFO T_NI
                ON T_ID.ID_OSHIRASE = T_NI.ID_OSHIRASE
    </update>

    <!-- お知らせ情報削除SQL：元テーブル更新のまま -->
    <delete id="delNoticeInfo" parameterType="com.toyotec_jp.uslim.common.model.NoticeDelParam">
        DELETE FROM ${uslimDb}.NOTICEINFO 
        WHERE ID_OSHIRASE = #{idOshirase}
    </delete>

</mapper>
