SELECT
    CASE
        WHEN no_frame IS NULL
          OR TRIM(no_frame) = ''
            THEN 'BLANK'

        WHEN REGEXP_LIKE(TRIM(no_frame), '^[0-9]+$')
            THEN 'DIGITS_ONLY'

        WHEN REGEXP_LIKE(TRIM(no_frame), '^[A-Za-z0-9]+$')
            THEN 'ALPHANUMERIC'

        WHEN REGEXP_LIKE(TRIM(no_frame), '^[A-Za-z0-9-]+$')
            THEN 'ALPHANUMERIC_HYPHEN'

        ELSE 'OTHER_FORMAT'
    END AS no_frame_format,
    COUNT(*) AS row_count
FROM ai21rep_pr_kudu.tbaz017m
GROUP BY
    CASE
        WHEN no_frame IS NULL
          OR TRIM(no_frame) = ''
            THEN 'BLANK'

        WHEN REGEXP_LIKE(TRIM(no_frame), '^[0-9]+$')
            THEN 'DIGITS_ONLY'

        WHEN REGEXP_LIKE(TRIM(no_frame), '^[A-Za-z0-9]+$')
            THEN 'ALPHANUMERIC'

        WHEN REGEXP_LIKE(TRIM(no_frame), '^[A-Za-z0-9-]+$')
            THEN 'ALPHANUMERIC_HYPHEN'

        ELSE 'OTHER_FORMAT'
    END
ORDER BY
    no_frame_format;




