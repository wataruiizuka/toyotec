SELECT
    LENGTH(TRIM(no_frame)) AS no_frame_length,
    COUNT(*) AS row_count,
    COUNT(DISTINCT TRIM(no_frame)) AS distinct_no_frame_count
FROM ai21rep_pr_kudu.tbaz017m
WHERE no_frame IS NOT NULL
  AND TRIM(no_frame) <> ''
GROUP BY
    LENGTH(TRIM(no_frame))
ORDER BY
    no_frame_length;




