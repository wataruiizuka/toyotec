SELECT
    YEAR(dt_johosaku) AS target_year,
    MONTH(dt_johosaku) AS target_month,
    COUNT(*) AS monthly_row_count
FROM ai21rep_pr_kudu.tbaz017m
WHERE dt_johosaku >= CAST('2024-07-01 00:00:00' AS TIMESTAMP)
  AND dt_johosaku IS NOT NULL
GROUP BY
    YEAR(dt_johosaku),
    MONTH(dt_johosaku)
ORDER BY
    target_year,
    target_month;



