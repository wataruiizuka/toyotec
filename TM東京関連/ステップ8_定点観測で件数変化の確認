SELECT
    'TBAZ017M' AS table_name,
    NOW() AS observed_at,
    COUNT(*) AS row_count,
    MAX(dt_johosaku) AS max_business_datetime,
    MAX(
        CASE
            WHEN dt_kosin <= NOW() THEN dt_kosin
            ELSE NULL
        END
    ) AS max_update_datetime,
    SUM(
        CASE
            WHEN dt_kosin > NOW() THEN 1
            ELSE 0
        END
    ) AS future_update_datetime_count
FROM ai21rep_pr_kudu.tbaz017m

UNION ALL

