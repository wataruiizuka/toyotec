SELECT
    COUNT(*) AS row_count,

    SUM(
        CASE
            WHEN dt_kosin > NOW() THEN 1
            ELSE 0
        END
    ) AS future_dt_kosin_count,

    MIN(
        CASE
            WHEN dt_kosin > NOW() THEN dt_kosin
            ELSE NULL
        END
    ) AS min_future_dt_kosin,

    MAX(
        CASE
            WHEN dt_kosin > NOW() THEN dt_kosin
            ELSE NULL
        END
    ) AS max_future_dt_kosin,

    SUM(
        CASE
            WHEN dt_kosin < dt_johosaku THEN 1
            ELSE 0
        END
    ) AS kosin_before_johosaku_count,

    SUM(
        CASE
            WHEN dt_kosin = dt_johosaku THEN 1
            ELSE 0
        END
    ) AS kosin_equal_johosaku_count,

    SUM(
        CASE
            WHEN dt_kosin > dt_johosaku THEN 1
            ELSE 0
        END
    ) AS kosin_after_johosaku_count

FROM ai21rep_pr_kudu.tbaz017m;
