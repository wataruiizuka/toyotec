SELECT
    COUNT(*) AS row_count,
    COUNT(dt_johosaku) AS dt_johosaku_count,
    COUNT(*) - COUNT(dt_johosaku) AS dt_johosaku_null_count,
    MIN(dt_johosaku) AS min_dt_johosaku,
    MAX(dt_johosaku) AS max_dt_johosaku,
    COUNT(dt_kosin) AS dt_kosin_count,
    COUNT(*) - COUNT(dt_kosin) AS dt_kosin_null_count,
    MIN(dt_kosin) AS min_dt_kosin,
    MAX(dt_kosin) AS max_dt_kosin
FROM ai21rep_pr_kudu.tbaz017m;
