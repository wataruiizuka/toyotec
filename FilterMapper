-- DM_FILTER_SITAYOTE
TRUNCATE TABLE ${uslimDb}.DM_FILTER_SITAYOTE;

INSERT INTO ${uslimDb}.DM_FILTER_SITAYOTE (
    cd_hansya,
    cd_kaisya,
    cd_hanbaitn,
    dd_sitayote,
    value,
    label,
    disp,
    mart_created_at
)
SELECT
    #{cdHansya},
    #{cdKaisya},
    #{cdHanbaitn},
    dd_sitayote,
    FROM_TIMESTAMP(dd_sitayote, 'yyyy/MM/dd') AS value,
    CASE
        WHEN dd_sitayote >= DATE'2019-05-01' THEN REPLACE(FROM_TIMESTAMP(dd_sitayote, 'yy(?)/MM/dd'), '?', 'R' || LPAD(CAST(YEAR(dd_sitayote) - 2018 AS STRING), 2, '0'))
        WHEN dd_sitayote >= DATE'1989-01-08' THEN REPLACE(FROM_TIMESTAMP(dd_sitayote, 'yy(?)/MM/dd'), '?', 'H' || LPAD(CAST(YEAR(dd_sitayote) - 1988 AS STRING), 2, '0'))
        WHEN dd_sitayote >= DATE'1926-12-25' THEN REPLACE(FROM_TIMESTAMP(dd_sitayote, 'yy(?)/MM/dd'), '?', 'S' || LPAD(CAST(YEAR(dd_sitayote) - 1925 AS STRING), 2, '0'))
        WHEN dd_sitayote >= DATE'1912-07-30' THEN REPLACE(FROM_TIMESTAMP(dd_sitayote, 'yy(?)/MM/dd'), '?', 'T' || LPAD(CAST(YEAR(dd_sitayote) - 1911 AS STRING), 2, '0'))
        WHEN dd_sitayote >= DATE'1868-09-08' THEN REPLACE(FROM_TIMESTAMP(dd_sitayote, 'yy(?)/MM/dd'), '?', 'M' || LPAD(CAST(YEAR(dd_sitayote) - 1867 AS STRING), 2, '0'))
        ELSE ''
    END AS label,
    '1' AS disp,
    CURRENT_TIMESTAMP
FROM ${uslimDb}.DM_FILTER_VEHICLE_BASE
WHERE source_type = 'SITA'
  AND cd_hansya = #{cdHansya}
  AND cd_kaisya = #{cdKaisya}
  AND dd_sitayote IS NOT NULL
GROUP BY dd_sitayote;


