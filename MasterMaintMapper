-- DM_RESERVE_STORE
TRUNCATE TABLE gold.DM_RESERVE_STORE;

INSERT INTO gold.DM_RESERVE_STORE (
    cd_hansya,
    cd_kaisya,
    cd_hanbaitn,
    cd_tenpo,
    kj_tentanms,
    mj_taisyoten,
    sort_cd_tenpo,
    mart_created_at
)
SELECT
    base.cd_hansya,
    base.cd_kaisya,
    usr.cd_hanbaitn,
    NVL(usr.cd_tenpo, base.rsm_cd_tenpo) AS cd_tenpo,
    NVL(REGEXP_REPLACE(tbv0201m.kj_tentanms, '[　 ]+$', ''), t_kts.kj_tentanms) AS kj_tentanms,
    NVL(base.mj_taisyoten, '0') AS mj_taisyoten,
    NVL(usr.cd_tenpo, base.rsm_cd_tenpo) AS sort_cd_tenpo,
    NOW()
FROM (
    SELECT
        COALESCE(t_user.cd_hansya, t_rsm.cd_hansya) AS cd_hansya,
        COALESCE(t_user.cd_kaisya, t_rsm.cd_kaisya) AS cd_kaisya,
        t_user.cd_tenpo,
        t_rsm.cd_tenpo AS rsm_cd_tenpo,
        t_rsm.mj_taisyoten
    FROM (
        SELECT
            cd_hansya,
            cd_kaisya,
            cd_hanbaitn,
            cd_tenpo
        FROM uslim_ve.USERINFO
        WHERE (mj_sakujo != '1' OR mj_sakujo IS NULL)
        GROUP BY cd_hansya, cd_kaisya, cd_hanbaitn, cd_tenpo
    ) t_user
    FULL JOIN (
        SELECT
            cd_hansya,
            cd_kaisya,
            cd_tenpo,
            mj_taisyoten
        FROM uslim_ve.RESERVESTOREMAINT
    ) t_rsm
      ON t_user.cd_hansya = t_rsm.cd_hansya
     AND t_user.cd_kaisya = t_rsm.cd_kaisya
     AND t_user.cd_tenpo = t_rsm.cd_tenpo
) base
LEFT JOIN (
    SELECT
        cd_hansya,
        cd_kaisya,
        cd_hanbaitn,
        cd_tenpo
    FROM uslim_ve.USERINFO
    WHERE (mj_sakujo != '1' OR mj_sakujo IS NULL)
    GROUP BY cd_hansya, cd_kaisya, cd_hanbaitn, cd_tenpo
) usr
  ON NVL(base.cd_tenpo, base.rsm_cd_tenpo) = usr.cd_tenpo
 AND base.cd_hansya = usr.cd_hansya
 AND base.cd_kaisya = usr.cd_kaisya
LEFT JOIN ai21rep_ve.TBV0201M tbv0201m
  ON base.cd_hansya = tbv0201m.cd_hansya
 AND base.cd_kaisya = tbv0201m.cd_kaisya
 AND NVL(base.cd_tenpo, base.rsm_cd_tenpo) = tbv0201m.cd_tenpo
LEFT JOIN uslim_ve.KPITARGETSTORE t_kts
  ON base.cd_hansya = t_kts.cd_hansya
 AND base.cd_kaisya = t_kts.cd_kaisya
 AND NVL(base.cd_tenpo, base.rsm_cd_tenpo) = t_kts.cd_tenpo;


