-- DM_CONDITIONSETTING

TRUNCATE TABLE gold.DM_CONDITIONSETTING;

INSERT INTO gold.DM_CONDITIONSETTING (
    cd_hansya,
    cd_kaisya,
    kb_range,
    kb_condition,
    key_item,
    mj_syamei,
    cd_maker,
    mart_created_at
)
SELECT
    cd_hansya,
    cd_kaisya,
    kb_range,
    kb_condition,
    key_item,
    mj_syamei,
    cd_maker,
    NOW()
FROM uslim_ve.CONDITIONSETTING;


-- DM_CONDITION_EXCEPT_MAKER

TRUNCATE TABLE gold.DM_CONDITION_EXCEPT_MAKER;

INSERT INTO gold.DM_CONDITION_EXCEPT_MAKER (
    cd_hansya,
    cd_kaisya,
    kb_range,
    cd_maker,
    mj_makermei,
    except_cd_maker,
    mart_created_at
)
SELECT
    tbv0205m.cd_hansya,
    tbv0205m.cd_kaisya,
    t_cs.kb_range,
    tbv0205m.cd_maker,
    NVL(REGEXP_REPLACE(tbv0205m.mj_makermei, '[　 ]+$', ''), '') AS mj_makermei,
    t_cs.key_item AS except_cd_maker,
    NOW()
FROM ai21rep_ve.TBV0205M tbv0205m
LEFT JOIN uslim_ve.CONDITIONSETTING t_cs
    ON tbv0205m.cd_hansya = t_cs.cd_hansya
   AND tbv0205m.cd_kaisya = t_cs.cd_kaisya
   AND tbv0205m.cd_maker = t_cs.key_item
   AND t_cs.kb_condition = '01';


