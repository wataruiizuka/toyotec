SELECT
    #{cdHansya} AS cd_hansya,
    #{cdKaisya} AS cd_kaisya,
    #{noSti} AS no_sti,
    TBNH008G.KB_STIKT,
    TBNH019M.CD_FGBUI,
    TBNH016M.MJ_FGBUI,
    TBNH019M.CD_SNSYO,
    TBNH011M.MJ_SNSYONA,
    TBNH011M.MJ_SNSYOKG,
    CURRENT_TIMESTAMP
FROM ${ai21Db}.TBNH008G TBNH008G
INNER JOIN ${ai21Db}.TBNH002G TBNH002G
    ON #{cdHansya} = TBNH002G.CD_HANSYA
   AND #{cdKaisya} = TBNH002G.CD_KAISYA
   AND #{noSti} = TBNH002G.NO_STI
   AND '1' = TBNH002G.MJ_STIHZSM
   AND TBNH008G.KB_STIKT = TBNH002G.KB_STIKT
LEFT JOIN /* +SHUFFLE */ ${ai21Db}.TBNH019M TBNH019M
    ON #{cdHansya} = TBNH019M.CD_HANSYA
   AND #{cdKaisya} = TBNH019M.CD_KAISYA
   AND TBNH008G.CD_STIKASI = TBNH019M.CD_STIKASI
   AND TBNH002G.DD_STISGJS BETWEEN TBNH019M.DD_TKIST AND TBNH019M.DD_TKIEND
LEFT JOIN /* +SHUFFLE */ ${ai21Db}.TBNH016M TBNH016M
    ON #{cdHansya} = TBNH016M.CD_HANSYA
   AND #{cdKaisya} = TBNH016M.CD_KAISYA
   AND TBNH019M.CD_FGBUI = TBNH016M.CD_FGBUI
   AND TBNH002G.DD_STISGJS BETWEEN TBNH016M.DD_TKIST AND TBNH016M.DD_TKIEND
LEFT JOIN /* +SHUFFLE */ ${ai21Db}.TBNH011M TBNH011M
    ON #{cdHansya} = TBNH011M.CD_HANSYA
   AND #{cdKaisya} = TBNH011M.CD_KAISYA
   AND TBNH019M.CD_SNSYO = TBNH011M.CD_SNSYO
   AND TBNH002G.DD_STISGJS BETWEEN TBNH011M.DD_TKIST AND TBNH011M.DD_TKIEND
WHERE TBNH008G.CD_HANSYA = #{cdHansya}
  AND TBNH008G.CD_KAISYA = #{cdKaisya}
  AND TBNH008G.NO_STI = #{noSti}
  AND TBNH008G.MJ_STIHZSM = '1';


