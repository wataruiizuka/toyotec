-- DM_DEVIATION_BIZ_PROC
TRUNCATE TABLE gold.DM_DEVIATION_BIZ_PROC;

INSERT INTO gold.DM_DEVIATION_BIZ_PROC (
    cd_hansya,
    cd_kaisya,
    cd_proc,
    kj_proc,
    cd_proc_dev,
    su_hyojijun,
    mart_created_at
)
SELECT
    t_plm.cd_hansya,
    t_plm.cd_kaisya,
    t_ppm.cd_proc,
    t_ppm.kj_proc,
    t_plm.cd_proc_dev,
    t_ppm.su_hyojijun,
    NOW()
FROM uslim_ve.PROCPHASEMAINT t_ppm
INNER JOIN uslim_ve.PROCLTMAINT t_plm
    ON t_ppm.cd_proc = t_plm.cd_proc
INNER JOIN uslim_ve.PROCPHASEMAINT t_ppmd
    ON t_ppmd.kb_proc_type = '3'
   AND t_ppmd.su_hyojijun = 1
   AND t_plm.cd_proc_dev = t_ppmd.cd_proc
WHERE t_ppm.kb_proc_type = '1';


