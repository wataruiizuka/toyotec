-- DM_DEVIATION_PROC_LT_MAINT
TRUNCATE TABLE gold.DM_DEVIATION_PROC_LT_MAINT;

INSERT INTO gold.DM_DEVIATION_PROC_LT_MAINT (
    cd_hansya,
    cd_kaisya,
    cd_proc_dev,
    kj_proc_dev,
    cd_prev_proc,
    cd_proc,
    nu_proc_lt,
    kb_uriag_list,
    cd_tenpo_list,
    sort_proc,
    sort_proc_dev,
    mart_created_at
)
SELECT
    base.target_cd_hansya AS cd_hansya,
    base.target_cd_kaisya AS cd_kaisya,
    base.cd_proc_dev,
    base.kj_proc_dev,
    base.cd_prev_proc,
    base.cd_proc,
    base.nu_proc_lt,
    t_pc.mj_fukainfo AS kb_uriag_list,
    t_tp.mj_fukainfo AS cd_tenpo_list,
    t_ppmp.su_hyojijun AS sort_proc,
    t_ppmd.su_hyojijun AS sort_proc_dev,
    NOW()
FROM (
    SELECT *
    FROM (
        SELECT
            m.target_cd_hansya,
            m.target_cd_kaisya,
            p.cd_proc_dev,
            p.kj_proc_dev,
            p.cd_prev_proc,
            p.cd_proc,
            p.nu_proc_lt,
            ROW_NUMBER() OVER (
                PARTITION BY m.target_cd_hansya, m.target_cd_kaisya, p.cd_proc_dev, p.cd_prev_proc, p.cd_proc
                ORDER BY CASE
                    WHEN p.cd_hansya = m.target_cd_hansya AND p.cd_kaisya = m.target_cd_kaisya THEN 1
                    ELSE 2
                END
            ) AS rn
        FROM uslim_ve.PROCLTMAINT p
        INNER JOIN (
            SELECT DISTINCT
                cd_hansya AS target_cd_hansya,
                cd_kaisya AS target_cd_kaisya,
                /* 共通販社・会社は固定値マスタや設定テーブルで持つ想定 */
                '${cdCmnHansya}' AS cd_cmn_hansya,
                '${cdCmnKaisya}' AS cd_cmn_kaisya
            FROM uslim_ve.HANSYAINFO
        ) m
          ON (p.cd_hansya = m.target_cd_hansya AND p.cd_kaisya = m.target_cd_kaisya)
          OR (p.cd_hansya = m.cd_cmn_hansya AND p.cd_kaisya = m.cd_cmn_kaisya)
    ) x
    WHERE x.rn = 1
) base
INNER JOIN uslim_ve.PROCPHASEMAINT t_ppmp
    ON t_ppmp.kb_proc_type = '2'
   AND CONCAT(base.cd_prev_proc, ',', base.cd_proc) = t_ppmp.cd_proc
INNER JOIN uslim_ve.PROCPHASEMAINT t_ppmd
    ON t_ppmd.kb_proc_type = '3'
   AND base.cd_proc_dev = t_ppmd.cd_proc
LEFT JOIN uslim_ve.PROCCONDITION t_pc
    ON base.target_cd_hansya = t_pc.cd_hansya
   AND base.target_cd_kaisya = t_pc.cd_kaisya
   AND t_pc.mj_kubunid = '01'
   AND base.cd_proc = t_pc.cd_kubun
LEFT JOIN uslim_ve.PROCCONDITION t_tp
    ON base.target_cd_hansya = t_tp.cd_hansya
   AND base.target_cd_kaisya = t_tp.cd_kaisya
   AND t_tp.mj_kubunid = '04'
   AND base.cd_proc = t_tp.cd_kubun;


