-- DM_PROPOSED_PLAN_REN_STATUS
TRUNCATE TABLE ${uslimDb}.DM_PROPOSED_PLAN_REN_STATUS;

INSERT INTO ${uslimDb}.DM_PROPOSED_PLAN_REN_STATUS (
    cd_hansya,
    cd_kaisya,
    no_syadaiba,
    exists_ren_status,
    mart_created_at
)
SELECT
    CD_HANSYA,
    CD_KAISYA,
    RTRIM(NO_SYADAIBA),
    COUNT(1),
    CURRENT_TIMESTAMP
FROM ${uslimDb}.RESERVEINFO
WHERE MJ_STETAS <> '0'
  AND MJ_SAKUJO = '0'
  AND (MJ_ZAIKOST IS NULL OR MJ_ZAIKOST NOT IN ('4','5'))
GROUP BY
    CD_HANSYA,
    CD_KAISYA,
    RTRIM(NO_SYADAIBA);


