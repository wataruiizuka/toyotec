-- DM_PROPOSED_PLAN_DETAIL
TRUNCATE TABLE ${uslimDb}.DM_PROPOSED_PLAN_DETAIL;

INSERT INTO ${uslimDb}.DM_PROPOSED_PLAN_DETAIL (
    cd_hansya,
    cd_kaisya,
    no_siretyum,
    no_syadaiba,
    dt_sakusei_key,
    mj_stetas,
    cd_tenpo,
    kj_tenpomei,
    kj_tanstaff,
    kj_rentanto,
    mj_bikou,
    dt_sakusei,
    dt_saisinup,
    dt_renzumi,
    mj_sakuseimail,
    mj_kousinmail,
    mj_sakujo,
    kj_okyakume,
    dd_sydan,
    mj_zaikost,
    no_cyumon,
    dd_sitatori,
    mart_created_at
)
SELECT
    T_RI.CD_HANSYA,
    T_RI.CD_KAISYA,
    T_RI.NO_SIRETYUM,
    T_RI.NO_SYADAIBA,
    FROM_TIMESTAMP(T_RI.DT_SAKUSEI, 'yyyy/MM/dd HH:mm:ss.SSSSSS') AS dt_sakusei_key,
    T_RI.MJ_STETAS,
    T_RI.CD_TENPO,
    REGEXP_REPLACE(T_RI.KJ_TENPOMEI, '[　 ]+$', ''),
    REGEXP_REPLACE(T_RI.KJ_TANSTAFF, '[　 ]+$', ''),
    TRIM(T_RI.KJ_RENTANTO),
    REGEXP_REPLACE(T_RI.MJ_BIKOU, '[　 ]+$', ''),
    FROM_TIMESTAMP(T_RI.DT_SAKUSEI, 'yyyy/MM/dd HH:mm:ss.SSSSSS'),
    FROM_TIMESTAMP(T_RI.DT_SAISINUP, 'yyyy/MM/dd HH:mm:ss.SSSSSS'),
    FROM_TIMESTAMP(T_RI.DT_RENZUMI, 'yyyy/MM/dd HH:mm:ss.SSSSSS'),
    T_RI.MJ_SAKUSEIMAIL,
    T_RI.MJ_KOUSINMAIL,
    T_RI.MJ_SAKUJO,
    REGEXP_REPLACE(T_RI.KJ_OKYAKUME, '[　 ]+$', ''),
    FROM_TIMESTAMP(T_RI.DD_SYDAN, 'yyyy/MM/dd'),
    TBBC001G.MJ_ZAIKOST,
    T_RI.NO_CYUMON,
    FROM_TIMESTAMP(T_RI.DD_SITATORI, 'yyyy/MM/dd'),
    CURRENT_TIMESTAMP
FROM ${uslimDb}.RESERVEINFO T_RI
LEFT JOIN ${ai21Db}.TBBC001G TBBC001G
  ON T_RI.CD_HANSYA = TBBC001G.CD_HANSYA
 AND T_RI.CD_KAISYA = TBBC001G.CD_KAISYA
 AND T_RI.NO_SYADAIBA = RTRIM(TBBC001G.NO_SYADAIBA)
 AND CAST(T_RI.DT_SAKUSEI AS DATE) <= CAST(TBBC001G.DD_SIIRE AS DATE)
 AND TBBC001G.DD_TORIKESI IS NULL
WHERE T_RI.NO_CYUMON IS NULL;


-- DM_PROPOSED_PLAN_SYARYO
TRUNCATE TABLE ${uslimDb}.DM_PROPOSED_PLAN_SYARYO;

INSERT INTO ${uslimDb}.DM_PROPOSED_PLAN_SYARYO (
    cd_hansya,
    cd_kaisya,
    cd_hanbaitn,
    kb_honten,
    cd_teanyote,
    cd_tenpo,
    status,
    no_syaryou,
    no_syadaiba,
    cd_syamei,
    mj_syamei,
    dd_sitasyuk,
    dd_siire,
    dd_henkouou,
    dd_sitayote,
    dd_sitatori,
    dd_sydan,
    kj_okyakume,
    dt_sakusei,
    dt_sakusei_key,
    kj_tanstaff,
    kj_tenpomei,
    mj_bikou,
    okureflg,
    no_siretyum,
    kb_uriagyot,
    su_syodotor,
    nu_soukoukm,
    cd_syufukre,
    cd_web,
    mj_sakuseimail,
    mj_kousinmail,
    nu_suhkt,
    mart_created_at
)
SELECT
    T_ALL.CD_HANSYA,
    T_ALL.CD_KAISYA,
    T_ALL.CD_HANBAITN,
    T_ALL.KB_HONTEN,
    T_ALL.CD_TEANYOTE,
    T_ALL.CD_TENPO,
    T_ALL.STATUS,
    T_ALL.NO_SYARYOU,
    T_ALL.NO_SYADAIBA,
    T_ALL.CD_SYAMEI,
    RTRIM(TBV0232M.MJ_SYAMEI) AS MJ_SYAMEI,
    T_ALL.DD_SITASYUK,
    T_ALL.DD_SIIRE,
    T_ALL.DD_HENKOUOU,
    T_ALL.DD_SITAYOTE,
    T_ALL.DD_SITATORI,
    T_ALL.DD_SYDAN,
    T_ALL.KJ_OKYAKUME,
    T_ALL.DT_SAKUSEI,
    TO_TIMESTAMP(T_ALL.DT_SAKUSEI, 'yyyy/MM/dd HH:mm:ss.SSSSSS'),
    T_ALL.KJ_TANSTAFF,
    T_ALL.KJ_TENPOMEI,
    T_ALL.MJ_BIKOU,
    T_ALL.OKUREFLG,
    T_ALL.NO_SIRETYUM,
    T_ALL.KB_URIAGYOT,
    T_ALL.SU_SYODOTOR,
    T_ALL.NU_SOUKOUKM,
    T_ALL.CD_SYUFUKRE,
    T_ALL.CD_WEB,
    T_ALL.MJ_SAKUSEIMAIL,
    T_ALL.MJ_KOUSINMAIL,
    T_ALL.NU_SUHKT,
    CURRENT_TIMESTAMP
FROM ${uslimDb}.DM_PROPOSED_PLAN_SYARYO_TMP T_ALL
INNER JOIN ${ai21Db}.TBV0232M TBV0232M
  ON T_ALL.CD_HANSYA = TBV0232M.CD_HANSYA
 AND T_ALL.CD_KAISYA = TBV0232M.CD_KAISYA
 AND T_ALL.CD_SYAMEI = TBV0232M.CD_SYAMEI;


